@app.route('/report')
def report():
    if 'user' not in session:
        return redirect(url_for('login'))
    transactions = load_data(DATA_FILE)

    report_data = {}
    for platform in ['gojek', 'grabfood', 'shopeefood']:
        items = sorted([t for t in transactions.values() if t['platform'] == platform],
                       key=lambda x: (x['date'], x['order_number']))
        if not items:
            continue
        times = [t['delivery_time'] for t in items]
        by_date = {}
        for t in items:
            by_date.setdefault(t['date'], []).append(t['delivery_time'])

        daily_stats = []
        for d, dtimes in sorted(by_date.items()):
            ma3 = calculate_ma_stats(dtimes, 3)
            daily_stats.append({
                "date": d,
                "count": len(dtimes),
                "avg": round(sum(dtimes)/len(dtimes), 2),
                "min": min(dtimes),
                "max": max(dtimes),
                "prediction_ma3": ma3['prediction'] if ma3 else "-"
            })

        overall = calculate_ma_stats(times, 3)
        report_data[platform] = {
            "daily": daily_stats,
            "overall_prediction": overall['prediction'] if overall else "-",
            "overall_mae": overall['mae'] if overall else "-",
            "total": len(times)
        }

    return render_template('report.html', report_data=report_data)

