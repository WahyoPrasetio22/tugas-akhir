def moving_average(data, period):
    if len(data) < period:
        return [], []
    ma = []
    for i in range(period - 1, len(data)):
        window = data[i - period + 1:i + 1]
        ma.append(round(sum(window) / period, 2))
    return ma

def calculate_ma_stats(data, period):
    if len(data) < period:
        return None

    ma_values = moving_average(data, period)
    if not ma_values:
        return None

    # Predict next value = last MA
    prediction = ma_values[-1]

    # MAE & RMSE
    actual = data[period-1:]
    errors = [abs(a - p) for a, p in zip(actual, ma_values)]
    mae = round(sum(errors) / len(errors), 4) if errors else 0
    mse = round(sum(e**2 for e in errors) / len(errors), 4) if errors else 0
    rmse = round(math.sqrt(mse), 4)
    mape = round(sum(abs(e/a)*100 for e, a in zip(errors, actual) if a != 0) / len(errors), 4) if errors else 0

    return {
        "ma_values": ma_values,
        "prediction": prediction,
        "mae": mae,
        "rmse": rmse,
        "mape": mape,
        "count": len(data),
        "avg": round(sum(data)/len(data), 2),
        "min": min(data),
        "max": max(data)
    }

