@app.route('/transactions')
def transactions():
    if 'user' not in session:
        return redirect(url_for('login'))
    data = load_data(DATA_FILE)
    platform = request.args.get('platform', '')
    date_filter = request.args.get('date', '')
    items = list(data.values())
    if platform:
        items = [t for t in items if t['platform'] == platform]
    if date_filter:
        items = [t for t in items if t['date'] == date_filter]
    items.sort(key=lambda x: (x['date'], x['order_number']))
    return render_template('transactions.html', transactions=items, platform=platform, date_filter=date_filter)

@app.route('/transactions/add', methods=['GET', 'POST'])
def add_transaction():
    if 'user' not in session:
        return redirect(url_for('login'))
    if request.method == 'POST':
        data = load_data(DATA_FILE)
        platform = request.form.get('platform')
        date_val = request.form.get('date')
        delivery_time = float(request.form.get('delivery_time'))
        customer = request.form.get('customer', '')
        notes = request.form.get('notes', '')
        # auto order number
        same_day = [t for t in data.values() if t['platform'] == platform and t['date'] == date_val]
        order_num = len(same_day) + 1
        tid = f"{platform}_{date_val}_{order_num}"
        data[tid] = {
            "id": tid,
            "platform": platform,
            "date": date_val,
            "order_number": order_num,
            "delivery_time": delivery_time,
            "customer": customer,
            "notes": notes
        }
        save_data(DATA_FILE, data)
        flash('Data berhasil ditambahkan!', 'success')
        return redirect(url_for('transactions'))
    return render_template('add_transaction.html')

@app.route('/transactions/delete/<tid>')
def delete_transaction(tid):
    if 'user' not in session:
        return redirect(url_for('login'))
    data = load_data(DATA_FILE)
    if tid in data:
        del data[tid]
        save_data(DATA_FILE, data)
        flash('Data berhasil dihapus!', 'success')
    return redirect(url_for('transactions'))

