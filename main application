@app.route('/api/analysis', methods=['POST'])
def api_analysis():
    body = request.json
    platform = body.get('platform', 'shopeefood')
    period = int(body.get('period', 3))
    date_from = body.get('date_from', '')
    date_to = body.get('date_to', '')

    transactions = load_data(DATA_FILE)
    items = [t for t in transactions.values() if t['platform'] == platform]
    if date_from:
        items = [t for t in items if t['date'] >= date_from]
    if date_to:
        items = [t for t in items if t['date'] <= date_to]
    items.sort(key=lambda x: (x['date'], x['order_number']))

    if not items:
        return jsonify({"error": "Tidak ada data untuk filter ini"})

    times = [t['delivery_time'] for t in items]
    labels = [f"{t['date']} #{t['order_number']}" for t in items]

    stats = calculate_ma_stats(times, period)
    if not stats:
        return jsonify({"error": f"Data tidak cukup untuk MA-{period}. Butuh minimal {period} data."})

    ma_labels = labels[period-1:]

    return jsonify({
        "labels": labels,
        "actual": times,
        "ma_labels": ma_labels,
        "ma_values": stats['ma_values'],
        "prediction": stats['prediction'],
        "mae": stats['mae'],
        "rmse": stats['rmse'],
        "mape": stats['mape'],
        "count": stats['count'],
        "avg": stats['avg'],
        "min": stats['min'],
        "max": stats['max'],
        "period": period,
        "platform": platform
    })

